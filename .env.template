# ─── PostgreSQL backend store (Neon or any PostgreSQL) ────
# Stores run metadata: parameters, metrics, tags
MLFLOW_BACKEND_STORE_URI="postgresql://user:password@host/dbname?sslmode=require&channel_binding=require"

# ─── AWS S3 artifact store ───
# Stores artifacts: model files (.pth), plots, etc.
AWS_ACCESS_KEY_ID="your_access_key_id"
AWS_SECRET_ACCESS_KEY="your_secret_access_key"
AWS_DEFAULT_REGION="eu-west-3"
S3_BUCKET_NAME="your_bucket_name"
MLFLOW_ARTIFACT_ROOT="s3://your_bucket_name/mlflow-artifacts"

# ─── Server configuration ───
PORT=7860
# Hosts allowed to send requests to this server
# Use "*" to allow all hosts (recommended for HuggingFace Spaces public deployment)
# Use "localhost,127.0.0.1" to restrict to local only
MLFLOW_ALLOWED_HOSTS="*"
# Origins allowed for CORS (comma-separated)
# Use "*" for public access, or restrict to specific origins
MLFLOW_CORS_ORIGINS="https://mouniat-vitiscanpro-diagno-api.hf.space,https://mouniat-vitiscan-streamlit.hf.space"

# ─── Optional: AWS credential check on startup ───
# Set to "yes" to verify AWS credentials before starting the server
# Useful for debugging — set to "no" in production to speed up startup
AWS_CHECK="no"

